            "type": "object",
            "properties": {
                "path": {
                    "type": "string",
                    "description": "Path where file will be written"
                },
                "content": {
                    "type": "string",
                    "description": "Text content to write"
                }
            },
            "required": [
                "path",
                "content"
            ]
        }
    },
    {
        "name": "append_to_file",
        "description": "Append text content to the end of an existing file without overwriting.",
        "inputSchema": {
            "type": "object",
            "properties": {
                "path": {
                    "type": "string",
                    "description": "Path to the file"
                },
                "content": {
                    "type": "string",
                    "description": "Text to append to the file"
                }
            },
            "required": [
                "path",
                "content"
            ]
        }
    },
    {
        "name": "replace_in_file",
        "description": "Find and replace specific text in a file. If multiple occurrences exist, replaces all.",
        "inputSchema": {
            "type": "object",
            "properties": {
                "path": {
                    "type": "string",
                    "description": "Path to the file"
                },
                "old_text": {
                    "type": "string",
                    "description": "Text to find in the file"
                },
                "new_text": {
                    "type": "string",
                    "description": "Replacement text"
                }
            },
            "required": [
                "path",
                "old_text",
                "new_text"
            ]
        }
    },
    {
        "name": "insert_after_marker",
        "description": "Insert text after a specific marker line in a file. Creates the file if it doesn't exist.",
        "inputSchema": {
            "type": "object",
            "properties": {
                "path": {
                    "type": "string",
                    "description": "Path to the file"
                },
                "marker": {
                    "type": "string",
                    "description": "Line content to search for"
                },
                "content": {
                    "type": "string",
                    "description": "Text to insert after the marker"
                }
            },
            "required": [
                "path",
                "marker",
                "content"
            ]
        }
    },
    {
        "name": "search_files",
        "description": "Search for text patterns within files in the sandbox directory.",
        "inputSchema": {
            "type": "object",
            "properties": {
                "query": {
                    "type": "string",
                    "description": "Text or regex pattern to search for"
                },
                "path": {
                    "type": "string",
                    "default": ".",
                    "description": "Directory path to search in (relative to the sandbox base)"
                },
                "pattern_type": {
                    "type": "string",
                    "default": "exact",
                    "enum": [
                        "exact",
                        "regex"
                    ],
                    "description": "Whether to treat query as exact text or regex pattern"
                },
                "max_results": {
                    "type": "integer",
                    "default": 20,
                    "description": "Maximum number of results to return"
                }
            },
            "required": [
                "query"
            ]
        }
    },
    {
        "name": "run_command",
        "description": "Execute a shell command within the sandbox directory. Policy blocks dangerous operations (rm -rf, sudo, apt, raw sh). Respects timeout and max_output limits.",
        "inputSchema": {
            "type": "object",
            "properties": {
                "command": {
                    "type": "string",
                    "description": "Shell command to execute"
                },
                "cwd": {
                    "type": "string",
                    "default": ".",
                    "description": "Working directory (relative to sandbox root)"
                },
                "timeout": {
                    "type": "integer",
                    "default": 15,
                    "description": "Max seconds to wait"
                },
                "max_output": {
                    "type": "integer",
                    "default": 5000,
                    "description": "Max characters of stdout/stderr to return"
                }
            },
            "required": [
                "command"
            ]
        }
    },
    {
        "name": "md_to_pdf",
        "description": "Convert a Markdown file to a styled PDF document using markdown, pdfkit, and wkhtmltopdf.",
        "inputSchema": {
            "type": "object",
            "properties": {
                "source_path": {
                    "type": "string",
                    "description": "Path to the source Markdown file (relative to the sandbox base)"
                },
                "output_path": {
                    "type": "string",
                    "description": "Path for the output PDF (defaults to same name with .pdf extension)"
                },
                "css_path": {
                    "type": "string",
                    "description": "Optional path to a custom CSS stylesheet (relative to the sandbox base)"
                }
            },
            "required": [
                "source_path"
            ]
        }
    },
    {
        "name": "delete_file",
        "description": "Delete a file from the sandbox directory.",
        "inputSchema": {
            "type": "object",
            "properties": {
                "path": {
                    "type": "string",
                    "description": "Path to the file to delete (relative to the sandbox base)"
                }
            },
            "required": [
                "path"
            ]
        }
    },
    {
        "name": "remove_directory",
        "description": "Remove a directory from the sandbox directory. Use recursive=true for non-empty directories.",
        "inputSchema": {
            "type": "object",
            "properties": {
                "path": {
                    "type": "string",
                    "description": "Path to the directory to remove (relative to the sandbox base)"
                },
                "recursive": {
                    "type": "boolean",
                    "default": false,
                    "description": "If true, removes directory and all contents recursively"
                }
            },
            "required": [
                "path"
            ]
        }
    },
    {
        "name": "store_context",
        "description": "Store or update project-specific context in SQLite knowledge base for cross-session persistence.",
        "inputSchema": {
            "type": "object",
            "properties": {
                "key": {
                    "type": "string",
                    "description": "Identifier for this context entry (e.g., 'auth-flow', 'known-issues')"
                },
                "content": {
                    "type": "string",
                    "description": "The actual context content to store"
                },
                "project": {
                    "type": "string",
                    "default": "default",
                    "description": "Project identifier to scope the context"
                }
            },
            "required": [
                "key",
                "content"
            ]
        }
    },
    {
        "name": "query_context",
        "description": "Query stored context using keyword search or direct key lookup. Key resolution checks canonical keys first, then aliases. Omit project for cross-project search. When listing all entries (no keyword/key), returns keys + title previews so caller can decide which to fetch in detail. Returns matching entries from SQLite knowledge base.",
        "inputSchema": {
            "type": "object",
            "properties": {
                "project": {
                    "type": "string",
                    "description": "Project identifier to filter results. Omit for cross-project search."
                },
                "keyword": {
                    "type": "string",
                    "description": "Keyword to search across all stored context (full-text search)"
                },
                "key": {
                    "type": "string",
                    "description": "Direct key lookup \u2014 resolves via canonical key or alias (alternative to keyword)"
                },
                "limit": {
                    "type": "integer",
                    "default": 20,
                    "description": "Maximum number of results to return"
                },
                "sort_by": {
                    "type": "string",
                    "enum": [
                        "updated_at",
                        "key"
                    ],
                    "default": "updated_at",
                    "description": "Sort order: updated_at (descending) or key (ascending)"
                }
            }
        }
    },
    {
        "name": "clear_context",
        "description": "Clear stored context entries. Either a specific key or all entries for a project. Keys resolve via canonical name or alias.",
        "inputSchema": {
            "type": "object",
            "properties": {
                "project": {
                    "type": "string",
                    "default": "default",
                    "description": "Project identifier to clear"
                },
                "key": {
                    "type": "string",
                    "description": "Specific key to clear \u2014 resolves via canonical name or alias (omit to clear entire project)"
                }
            }
        }
    },
    {
        "name": "add_context_alias",
        "description": "Add an alternate name (alias) for an existing context entry. The alias can be used in place of the canonical key in store/query/clear operations.",
        "inputSchema": {
            "type": "object",
            "properties": {
                "context_key": {
                    "type": "string",
                    "description": "The canonical key of the context entry to alias"
                },
                "alias_name": {
                    "type": "string",
                    "description": "The alternate name to register as an alias"
                },
                "project": {
                    "type": "string",
                    "default": "default",
                    "description": "Project identifier to scope the alias"
                }
            },
            "required": [
                "context_key",
                "alias_name"
            ]
        }
    },
    {
        "name": "list_projects",
        "description": "List all known projects in the SQLite knowledge base with last update timestamps.",
        "inputSchema": {
            "type": "object",
            "properties": {}
        }
    },
    {
        "name": "add_project_change",
        "description": "Record a new project change entry (bugfix, refactor, feature, milestone, config, or other).",
        "inputSchema": {
            "type": "object",
            "properties": {
                "project": {
                    "type": "string",
                    "description": "Project identifier (e.g., 'mcp-server', 'bob')"
                },
                "key": {
                    "type": "string",
                    "description": "Human-readable sub-key within project (e.g., 'fix-context-list')"
                },
                "change_type": {
                    "type": "string",
                    "enum": [
                        "bugfix",
                        "refactor",
                        "feature",
                        "milestone",
                        "config",
                        "other"
                    ],
                    "description": "Category of change"
                },
                "summary": {
                    "type": "string",
                    "description": "One-line description of what changed"
                }
            },
            "required": [
                "project",
                "key",
                "change_type",
                "summary"
            ]
        }
    },
    {
        "name": "add_change_step",
        "description": "Add a timeline step to an existing project change.",
        "inputSchema": {
            "type": "object",
            "properties": {
                "change_key": {
                    "type": "string",
                    "description": "The key of the change to add a step to"
                },
                "project": {
                    "type": "string",
                    "description": "Project identifier"
                },
                "step": {
                    "type": "string",
                    "description": "Stage name (e.g., 'identified root cause', 'implemented fix', 'tested')"
                },
                "date": {
                    "type": "string",
                    "description": "Date this step occurred (YYYY-MM-DD)"
                },
                "details": {
                    "type": "string",
                    "description": "Detailed description of what happened"
                },
                "files_changed": {
                    "type": "string",
                    "description": "Comma-separated file paths or JSON array"
                }
            },
            "required": [
                "change_key",
                "project",
                "step",
                "date"
            ]
        }
    },
