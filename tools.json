    {
        "name": "list_files",
        "description": "List files and directories in a specified folder. Use recursive=true for a full tree view of the directory structure.",
        "inputSchema": {
            "type": "object",
            "properties": {
                "path": {
                    "type": "string",
                    "description": "Absolute or relative path to list"
                },
                "recursive": {
                    "type": "boolean",
                    "default": false,
                    "description": "If true, show a recursive tree view of all subdirectories"
                }
            },
