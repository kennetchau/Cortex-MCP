        "inputSchema": {
            "type": "object",
            "properties": {
                "path": {
                    "type": "string",
                    "description": "Path to the file (relative to the sandbox base)"
                },
                "line_start": {
                    "type": "integer",
                    "default": 1,
                    "description": "Starting line number (1-indexed). Use negative values to count from end."
                },
                "line_count": {
                    "type": "integer",
                    "default": 50,
                    "description": "Number of lines to read"
                }
            },
            "required": [
                "path"
            ]
        }
    },
    {
        "name": "write_file",
